# ── .env.example ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running docker-compose.
# The .env file must NOT be committed to git (it's already in .gitignore).
# ----------------------------------------------------------------------------

# PostgreSQL credentials (used by both the `db` and `backend` services)
POSTGRES_USER=library_user
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=library_db

# JWT secret key — use a long random string in production
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=super-secret-change-me-in-production
